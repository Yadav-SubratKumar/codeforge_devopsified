# ─── CodeForge Environment Variables ─────────────────────────────────────────
# Copy this to .env and fill in values before running

# Backend
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://codeforge:secret@localhost:5432/codeforge_db
REDIS_URL=redis://:redissecret@localhost:6379
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING_IN_PRODUCTION
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# Frontend
VITE_API_URL=http://localhost:5000/api
